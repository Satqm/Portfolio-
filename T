<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Deep Dive ✦ Observe with Satyam</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;800&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
/* ═══════════════════════════════════════════════════════════
   DESIGN SYSTEM — NAVY × GOLD × BLUEPRINT × TERMINAL
   (All styles from previous version are retained. For brevity,
    we keep the same CSS as in the last fully functional build.)
═══════════════════════════════════════════════════════════ */
:root {
  --navy-900: #020b18;
  --navy-800: #050f22;
  --navy-700: #091428;
  --navy-600: #0e1e3a;
  --navy-500: #142848;
  --navy-400: #1e3a64;
  --navy-300: #2a5080;
  --gold-500: #d4a017;
  --gold-400: #e8b820;
  --gold-300: #f5ca3a;
  --gold-200: #fbd96a;
  --gold-glow: rgba(212,160,23,0.25);
  --gold-soft: rgba(212,160,23,0.08);
  --teal-500: #00c8b8;
  --teal-400: #00e5d4;
  --teal-glow: rgba(0,200,184,0.22);
  --bg: var(--navy-900);
  --bg-card: rgba(9,20,40,0.88);
  --bg-card-hover: rgba(14,30,58,0.96);
  --bg-glass: rgba(255,255,255,0.03);
  --bg-sidebar: rgba(2,10,22,0.97);
  --bg-header: rgba(5,15,34,0.96);
  --surface: rgba(14,30,58,0.65);
  --surface-dark: rgba(2,8,18,0.55);
  --text: #dde8ff;
  --text-dim: #6a80a8;
  --text-muted: #2a3a58;
  --border: rgba(212,160,23,0.15);
  --border-soft: rgba(255,255,255,0.06);
  --border-teal: rgba(0,200,184,0.2);
  --border-gold: rgba(212,160,23,0.3);
  --danger: #e05050;
  --success: #00cc88;
  --purple: #a87bff;
  --font-display: 'Orbitron', monospace;
  --font-body: 'IBM Plex Sans', sans-serif;
  --font-mono: 'IBM Plex Mono', 'Share Tech Mono', monospace;
  --font-terminal: 'Share Tech Mono', monospace;
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 18px;
  --t: 0.26s;
  --ease: cubic-bezier(0.16,1,0.3,1);
  --spring: cubic-bezier(0.34,1.56,0.64,1);
  --sidebar-w: 240px;
  --topbar-h: 52px;
}
body.light {
  --bg: #f0f5ff;
  --bg-card: rgba(255,255,255,0.95);
  --bg-card-hover: #ffffff;
  --bg-glass: rgba(0,0,0,0.02);
  --bg-sidebar: rgba(240,245,255,0.97);
  --bg-header: rgba(248,251,255,0.97);
  --surface: rgba(225,235,255,0.75);
  --surface-dark: rgba(200,215,248,0.8);
  --text: #0c1a30;
  --text-dim: #3a5078;
  --text-muted: #8aa0c0;
  --border: rgba(180,130,0,0.2);
  --border-soft: rgba(0,0,0,0.07);
  --border-teal: rgba(0,150,140,0.2);
  --border-gold: rgba(180,130,0,0.28);
  --gold-500: #b08010;
  --gold-400: #c89018;
  --gold-300: #dba020;
  --gold-glow: rgba(180,130,0,0.2);
  --gold-soft: rgba(180,130,0,0.07);
  --teal-500: #00a898;
  --teal-400: #00c0ae;
  --teal-glow: rgba(0,160,150,0.18);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  font-size: 14px;
  line-height: 1.6;
  transition: background var(--t), color var(--t);
}
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(212,160,23,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(212,160,23,0.04) 1px, transparent 1px),
    linear-gradient(rgba(30,80,180,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(30,80,180,0.06) 1px, transparent 1px);
  background-size: 80px 80px, 80px 80px, 20px 20px, 20px 20px;
}
body.light::before {
  background-image:
    linear-gradient(rgba(180,130,0,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(180,130,0,0.05) 1px, transparent 1px),
    linear-gradient(rgba(30,80,180,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(30,80,180,0.04) 1px, transparent 1px);
  background-size: 80px 80px, 80px 80px, 20px 20px, 20px 20px;
}
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 50% at 10% 5%, rgba(212,160,23,0.06) 0%, transparent 65%),
    radial-gradient(ellipse 50% 40% at 90% 95%, rgba(0,200,184,0.04) 0%, transparent 65%);
}
body.light::after { display: none; }
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-gold); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: var(--gold-400); }
.app-shell { display: flex; min-height: 100vh; position: relative; z-index: 1; }
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  position: fixed;
  top: 0; left: 0; z-index: 300;
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border-gold);
  display: flex; flex-direction: column;
  backdrop-filter: blur(20px);
  transition: transform var(--t) var(--ease);
  box-shadow: 2px 0 32px rgba(0,0,0,0.5), inset -1px 0 0 rgba(212,160,23,0.08);
}
.sidebar::before {
  content: '';
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.025) 2px, rgba(0,0,0,0.025) 4px);
  opacity: 0.6;
}
.sidebar-accent {
  height: 2px;
  background: linear-gradient(90deg, var(--gold-500), var(--gold-300), var(--gold-500));
  box-shadow: 0 0 12px var(--gold-glow);
  flex-shrink: 0;
}
.sidebar-header {
  padding: 1rem 1rem 0.75rem;
  border-bottom: 1px solid var(--border-gold);
  flex-shrink: 0;
  position: relative; z-index: 1;
}
.brand-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.brand-icon {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--gold-500), var(--gold-300));
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-weight: 800; font-size: 0.85rem; color: var(--navy-900);
  box-shadow: 0 0 18px var(--gold-glow), 0 2px 8px rgba(0,0,0,0.4);
  flex-shrink: 0;
}
.brand-text-wrap { flex: 1; }
.brand-title {
  font-family: var(--font-display);
  font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em;
  color: var(--gold-300); text-transform: uppercase;
  line-height: 1.3;
}
.brand-sub {
  font-family: var(--font-terminal);
  font-size: 0.58rem; color: var(--text-dim);
  letter-spacing: 0.05em;
  margin-top: 1px;
}
.sidebar-section-label {
  font-family: var(--font-terminal);
  font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text-muted);
  padding: 0.9rem 1rem 0.35rem;
  display: flex; align-items: center; gap: 0.4rem;
}
.sidebar-section-label::before {
  content: '//';
  color: var(--gold-500);
  font-family: var(--font-terminal);
}
.sidebar-nav {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 0 0.5rem;
  position: relative; z-index: 1;
  scrollbar-width: none;
}
.sidebar-nav::-webkit-scrollbar { display: none; }
.nav-item {
  display: flex; align-items: center; gap: 0.65rem;
  padding: 0.52rem 0.75rem;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--t) var(--ease);
  margin-bottom: 2px;
  position: relative;
  border: 1px solid transparent;
  color: var(--text-dim);
  font-family: var(--font-body);
  font-size: 0.82rem; font-weight: 500;
  user-select: none;
}
.nav-item:hover {
  background: var(--gold-soft);
  color: var(--text);
  border-color: rgba(212,160,23,0.15);
}
.nav-item.active {
  background: linear-gradient(135deg, rgba(212,160,23,0.16), rgba(212,160,23,0.06));
  color: var(--gold-300);
  border-color: var(--border-gold);
  font-weight: 700;
  box-shadow: 0 0 12px var(--gold-glow), inset 0 1px 0 rgba(255,255,255,0.04);
}
.nav-item.active::before {
  content: '';
  position: absolute; left: 0; top: 20%; bottom: 20%;
  width: 2.5px;
  background: linear-gradient(180deg, var(--gold-400), var(--gold-500));
  border-radius: 0 2px 2px 0;
  box-shadow: 0 0 8px var(--gold-glow);
}
.nav-item-icon {
  width: 20px; height: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; flex-shrink: 0;
  opacity: 0.7;
}
.nav-item.active .nav-item-icon,
.nav-item:hover .nav-item-icon { opacity: 1; }
.nav-item-badge {
  font-family: var(--font-terminal);
  font-size: 0.5rem; color: var(--gold-500);
  margin-left: auto; opacity: 0;
  transition: opacity var(--t);
  letter-spacing: 0.05em;
}
.nav-item:hover .nav-item-badge,
.nav-item.active .nav-item-badge { opacity: 1; }
.sidebar-footer {
  padding: 0.75rem 1rem;
  border-top: 1px solid var(--border-gold);
  flex-shrink: 0;
  position: relative; z-index: 1;
}
.sidebar-footer-controls {
  display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
  margin-bottom: 0.65rem;
}
.sidebar-ctrl-btn {
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-soft);
  background: var(--bg-glass);
  color: var(--text-dim); font-size: 0.75rem;
  cursor: pointer; text-decoration: none;
  transition: all 0.2s;
}
.sidebar-ctrl-btn:hover {
  border-color: var(--border-gold);
  color: var(--gold-400);
  background: var(--gold-soft);
}
.yt-btn {
  width: 100%;
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  background: linear-gradient(135deg, #e01a1a, #9a0000);
  color: #fff; border: none;
  padding: 0.42rem 0.8rem; border-radius: var(--radius-md);
  font-family: var(--font-body); font-weight: 700; font-size: 0.75rem;
  cursor: pointer; text-decoration: none;
  box-shadow: 0 0 18px rgba(224,26,26,0.4);
  transition: transform 0.2s, box-shadow 0.2s;
  letter-spacing: 0.03em;
  animation: ytPulse 2.5s ease-in-out infinite;
}
@keyframes ytPulse { 0%,100%{box-shadow:0 0 14px rgba(224,26,26,.4);} 50%{box-shadow:0 0 28px rgba(224,26,26,.65),0 0 42px rgba(224,26,26,.2);} }
.yt-btn:hover { transform: scale(1.03); }
.topbar {
  display: none;
  position: sticky; top: 0; z-index: 250;
  height: var(--topbar-h);
  background: var(--bg-header);
  border-bottom: 1px solid var(--border-gold);
  backdrop-filter: blur(20px);
  align-items: center; justify-content: space-between;
  padding: 0 1rem;
  box-shadow: 0 2px 20px rgba(0,0,0,0.35);
  flex-shrink: 0;
}
.topbar-title {
  font-family: var(--font-display);
  font-size: 0.72rem; font-weight: 700;
  color: var(--gold-300); letter-spacing: 0.07em;
  text-transform: uppercase;
}
.hamburger {
  width: 34px; height: 34px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border-gold);
  border-radius: var(--radius-md);
  background: var(--gold-soft);
  color: var(--gold-400); font-size: 0.85rem;
  cursor: pointer;
}
.sidebar-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 299;
  background: rgba(0,0,0,0.62);
  backdrop-filter: blur(4px);
}
.sidebar-overlay.open { display: block; }
.main-area {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  display: flex; flex-direction: column;
  transition: margin-left var(--t) var(--ease);
  overflow: hidden;
}
.progress-bar {
  height: 2px;
  background: var(--navy-600);
  flex-shrink: 0;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold-500), var(--gold-300));
  box-shadow: 0 0 8px var(--gold-glow);
  transition: width 0.35s var(--ease);
}
.panels-viewport {
  flex: 1;
  position: relative;
  overflow: hidden;
  touch-action: pan-y;
}
.panels-track {
  display: flex;
  height: 100%;
  will-change: transform;
  transition: transform 0.38s cubic-bezier(0.4,0,0.2,1);
}
.panel {
  min-width: 100%;
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  flex-shrink: 0;
}
.swipe-indicator {
  position: fixed;
  bottom: 1.2rem; left: 50%; transform: translateX(-50%);
  display: none;
  align-items: center; gap: 0.45rem;
  background: rgba(212,160,23,0.12);
  border: 1px solid var(--border-gold);
  border-radius: 999px;
  padding: 0.35rem 0.9rem;
  font-family: var(--font-terminal);
  font-size: 0.6rem; color: var(--gold-400);
  letter-spacing: 0.06em;
  z-index: 200;
  animation: swipeFade 4s ease-in-out forwards;
  pointer-events: none;
}
@keyframes swipeFade {
  0%{opacity:0;transform:translateX(-50%) translateY(8px);}
  15%{opacity:1;transform:translateX(-50%) translateY(0);}
  75%{opacity:1;}
  100%{opacity:0;transform:translateX(-50%) translateY(-4px);}
}
.status-bar {
  height: 22px;
  background: var(--bg-sidebar);
  border-top: 1px solid var(--border-gold);
  display: flex; align-items: center;
  padding: 0 1rem; gap: 1.2rem;
  flex-shrink: 0;
}
.status-item {
  font-family: var(--font-terminal);
  font-size: 0.56rem; color: var(--text-muted);
  display: flex; align-items: center; gap: 0.3rem;
  letter-spacing: 0.06em; text-transform: uppercase;
}
.status-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 6px rgba(0,204,136,0.7);
  animation: dotBlink 2s ease-in-out infinite;
}
@keyframes dotBlink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
.status-item.gold { color: var(--gold-400); }
.container { max-width: 1020px; margin: 0 auto; padding: 1.8rem 1.5rem 5rem; }
.hero { text-align: center; padding: 2.5rem 1rem 1.8rem; position: relative; }
.hero::before {
  content: attr(data-num);
  position: absolute; top: 0.8rem; left: 50%; transform: translateX(-50%);
  font-family: var(--font-display);
  font-size: 5rem; font-weight: 800;
  color: rgba(212,160,23,0.06);
  pointer-events: none; letter-spacing: 0.1em; line-height: 1;
}
.eyebrow {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: var(--gold-soft);
  border: 1px solid var(--border-gold);
  color: var(--gold-400);
  font-family: var(--font-terminal);
  font-size: 0.65rem; font-weight: 600;
  padding: 0.3rem 0.9rem; border-radius: 3px;
  margin-bottom: 1rem;
  letter-spacing: 0.1em; text-transform: uppercase;
}
.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 4.5vw, 3rem);
  font-weight: 800; line-height: 1.08; letter-spacing: 0.02em;
  text-transform: uppercase;
  background: linear-gradient(135deg, var(--text) 30%, var(--gold-400));
  -webkit-background-clip: text; background-clip: text; color: transparent;
  margin-bottom: 0.9rem;
}
body.light .hero h1 {
  background: linear-gradient(135deg, #0c1a30 30%, var(--gold-500));
}
.hero p { color: var(--text-dim); font-size: 0.92rem; max-width: 520px; margin: 0 auto; line-height: 1.75; }
.section-title {
  font-family: var(--font-display);
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text);
  margin: 2.2rem 0 1rem;
  display: flex; align-items: center; gap: 0.6rem;
  padding-left: 0.75rem;
  border-left: 2.5px solid var(--gold-500);
}
.card {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-top: 1.5px solid var(--border-gold);
  border-radius: var(--radius-lg);
  overflow: hidden; margin-bottom: 1.1rem;
  backdrop-filter: blur(16px) saturate(140%);
  box-shadow: 0 2px 22px rgba(0,0,0,0.25), inset 0 1px 0 rgba(212,160,23,0.04);
  transition: all var(--t) var(--ease);
}
.card:hover {
  border-top-color: var(--gold-400);
  box-shadow: 0 8px 36px rgba(0,0,0,0.32), 0 0 0 1px var(--border-gold);
  transform: translateY(-1px);
}
.card-hd {
  display: flex; align-items: center; gap: 0.85rem;
  padding: 0.85rem 1.35rem;
  background: rgba(212,160,23,0.03);
  border-bottom: 1px solid var(--border-soft);
  flex-wrap: wrap;
}
.card-hd h2 {
  font-family: var(--font-display);
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--text);
}
.step-badge {
  width: 28px; height: 28px; border-radius: var(--radius-sm); flex-shrink: 0;
  background: linear-gradient(135deg, var(--gold-500), var(--gold-300));
  color: var(--navy-900); font-weight: 800; font-size: 0.72rem;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 12px var(--gold-glow);
  font-family: var(--font-display);
}
.card-bd { padding: 1.25rem 1.35rem; }
@media(max-width:600px){.card-bd{padding:1rem;}}
/* --- attention simulator styles (same as previous) --- */
.tokens-row{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;padding:.85rem 0;}
.token{padding:.42rem .9rem;border-radius:var(--radius-sm);background:var(--gold-soft);border:1.5px solid rgba(212,160,23,0.2);font-family:var(--font-mono);font-size:.82rem;font-weight:500;cursor:pointer;transition:all var(--t) var(--ease);color:var(--text-dim);}
.token:hover{border-color:var(--gold-400);background:rgba(212,160,23,0.12);transform:translateY(-2px);color:var(--text);box-shadow:0 4px 14px var(--gold-glow);}
.token.selected{background:var(--gold-500);color:var(--navy-900);border-color:var(--gold-400);font-weight:700;transform:translateY(-2px);box-shadow:0 0 20px var(--gold-glow);}
.qkv-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.9rem;}
@media(max-width:640px){.qkv-grid{grid-template-columns:1fr;}}
.qkv-card{background:var(--surface-dark);border-radius:var(--radius-md);border:1px solid var(--border-soft);padding:1rem;backdrop-filter:blur(8px);}
.bar-list{display:flex;flex-direction:column;gap:.5rem;}
.bar-row{display:flex;align-items:center;gap:.65rem;}
.bar-label{font-family:var(--font-mono);font-size:.76rem;width:64px;flex-shrink:0;color:var(--text-dim);}
.bar-track{flex:1;height:16px;background:rgba(255,255,255,.04);border-radius:var(--radius-sm);overflow:hidden;border:1px solid rgba(255,255,255,.04);}
.bar-fill{height:100%;border-radius:var(--radius-sm);background:linear-gradient(90deg,var(--gold-500),var(--gold-300));transition:width .65s var(--spring);}
.bar-val{font-family:var(--font-mono);font-size:.72rem;width:40px;text-align:right;color:var(--text-dim);}
.heatmap-wrap{overflow-x:auto;padding-bottom:.5rem;}
.heatmap-grid{display:grid;gap:3px;min-width:460px;}
.hm-cell{height:34px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:.68rem;cursor:pointer;transition:all .15s;border:1px solid transparent;}
.hm-cell:hover{transform:scale(1.08);border-color:var(--gold-400);}
.hm-cell.row-highlight{border-color:var(--gold-500);box-shadow:0 0 6px var(--gold-glow);}
.flow-vis{position:relative;padding:1rem 0;min-height:150px;}
.flow-tokens-row{display:flex;justify-content:space-around;position:relative;z-index:2;min-width:360px;overflow-x:auto;}
.flow-tok-box{padding:.38rem .65rem;border-radius:var(--radius-sm);font-family:var(--font-mono);font-size:.76rem;border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);}
.flow-tok-box.src{border-color:var(--gold-400);background:rgba(212,160,23,0.12);color:var(--gold-300);}
#flow-svg{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;}
.explain-box{background:rgba(212,160,23,0.05);border:1px solid rgba(212,160,23,0.15);border-left:3px solid var(--gold-500);border-radius:0 var(--radius-md) var(--radius-md) 0;padding:.85rem 1rem;font-size:.85rem;line-height:1.75;color:var(--text-dim);}
.formula-box{background:var(--surface-dark);border:1px solid var(--border-gold);border-radius:var(--radius-md);padding:.85rem;text-align:center;margin:.85rem 0;font-family:var(--font-mono);word-break:break-all;color:var(--gold-300);font-size:.88rem;}
.llm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:.7rem;}
.llm-card{background:rgba(0,0,0,.18);border:1px solid var(--border-soft);border-top:1.5px solid var(--border-gold);border-radius:var(--radius-md);padding:.85rem;text-align:center;font-size:.83rem;}
.llm-card-icon{font-size:1.3rem;margin-bottom:.3rem;}
.sim10-controls{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.9rem;}
.ctrl-btn{width:32px;height:32px;border-radius:var(--radius-sm);border:1px solid var(--border-gold);background:var(--gold-soft);color:var(--text);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.8rem;}
.ctrl-btn.primary{background:var(--gold-500);color:var(--navy-900);border-color:var(--gold-400);box-shadow:0 0 12px var(--gold-glow);}
.s10-phases{display:flex;gap:.35rem;overflow-x:auto;padding:.35rem 0 .65rem;}
.s10-ph{padding:.32rem .8rem;border-radius:var(--radius-sm);font-family:var(--font-mono);font-size:.68rem;font-weight:600;cursor:pointer;white-space:nowrap;border:1px solid rgba(255,255,255,.07);color:var(--text-dim);}
.s10-ph.done{border-color:rgba(212,160,23,.35);color:var(--gold-400);}
.s10-ph.active{background:var(--gold-500);color:var(--navy-900);border-color:var(--gold-400);box-shadow:0 0 10px var(--gold-glow);}
.s10-canvas{background:var(--surface-dark);border-radius:var(--radius-lg);padding:1.3rem 1.1rem;min-height:230px;overflow-x:auto;border:1px solid var(--border-gold);}
.s10-explain{display:flex;align-items:flex-start;gap:.75rem;margin-top:1rem;padding:.85rem 1rem;background:rgba(212,160,23,.06);border-radius:var(--radius-md);border-left:3px solid var(--gold-500);}
.s10-explain-icon{font-size:1.3rem;flex-shrink:0;}
.s10-explain-text{font-size:.84rem;line-height:1.75;color:var(--text-dim);}
.focus-chip{background:var(--gold-soft);padding:.26rem .65rem;border-radius:var(--radius-sm);font-family:var(--font-terminal);font-size:.68rem;border:1px solid var(--border-gold);color:var(--gold-300);}
.v-box{border-radius:var(--radius-md);border:1.5px solid rgba(255,255,255,.08);background:rgba(5,12,28,.9);padding:.55rem .72rem;text-align:center;}
.v-box.lit{border-color:var(--gold-400);box-shadow:0 0 0 2px rgba(212,160,23,.12);}
.v-lbl{font-family:var(--font-terminal);font-size:.58rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.2rem;}
.v-val{font-family:var(--font-mono);font-size:.68rem;color:var(--text-dim);line-height:1.4;}
.wsum-row{display:flex;align-items:center;gap:.55rem;margin-bottom:5px;}
.wsum-tok{font-family:var(--font-mono);font-size:.68rem;width:56px;flex-shrink:0;color:var(--text-dim);}
.wsum-track{flex:1;height:14px;background:rgba(255,255,255,.04);border-radius:var(--radius-sm);overflow:hidden;}
.wsum-fill{height:100%;border-radius:var(--radius-sm);background:linear-gradient(90deg,var(--gold-500),var(--gold-300));transition:width .5s var(--spring);}
.wsum-fill.gold{background:linear-gradient(90deg,#c88000,#f5ca3a);}
.wsum-val{font-family:var(--font-mono);font-size:.66rem;width:34px;text-align:right;color:var(--text-dim);}
.out-pop{animation:outPop .45s ease forwards;}
@keyframes outPop{from{transform:scale(.85);opacity:0;}60%{transform:scale(1.05);}to{transform:scale(1);opacity:1;}}
.s10-hm{display:grid;gap:2px;}
.s10-hm-cell{height:24px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:.6rem;}
.s10-hm-cell.row-active{outline:1.5px solid var(--gold-400);}
/* --- agentic loop styles (retain full style) --- */
.loop-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin: 1.2rem 0;
}
@media(max-width:700px){.loop-wrap{grid-template-columns:1fr;}}
.loop-ring-container {
  position: relative;
  max-width: 300px;
  margin: 0 auto;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loop-outer-ring {
  position: absolute; inset: 0;
  border-radius: 50%;
  border: 1.5px solid var(--border-gold);
  box-shadow: 0 0 0 6px rgba(212,160,23,0.03), 0 0 25px rgba(212,160,23,0.06);
}
.loop-mid-ring {
  position: absolute; inset: 12%;
  border-radius: 50%;
  border: 1px dashed rgba(212,160,23,0.2);
  animation: spin 24s linear infinite;
}
.loop-inner-ring {
  position: absolute; inset: 25%;
  border-radius: 50%;
  border: 1px solid rgba(0,200,184,0.15);
  animation: spin 40s linear infinite reverse;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loop-center {
  position: absolute; inset: 38%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-soft), rgba(212,160,23,0.04));
  border: 1px solid var(--border-gold);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 0.46rem; font-weight: 700;
  color: var(--gold-400); letter-spacing: 0.06em; text-align: center;
  text-transform: uppercase;
  z-index: 5;
}
.loop-node-card {
  position: absolute;
  width: 82px;
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-top: 2px solid var(--gold-500);
  border-radius: var(--radius-md);
  padding: 0.55rem 0.45rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s var(--spring);
  backdrop-filter: blur(12px);
  z-index: 10;
}
.loop-node-card[data-pos="top"]    { top: -4px;  left: 50%; transform: translateX(-50%); }
.loop-node-card[data-pos="right"]  { right: -4px; top:50%;  transform: translateY(-50%); }
.loop-node-card[data-pos="bottom"] { bottom: -4px;left: 50%; transform: translateX(-50%); }
.loop-node-card[data-pos="left"]   { left: -4px; top: 50%; transform: translateY(-50%); }
.loop-node-card.ring-active { border-top-color: var(--gold-300); background: rgba(212,160,23,0.1); transform: scale(1.08); }
.loop-node-icon { font-size: 1.3rem; margin-bottom: 0.2rem; }
.loop-node-label {
  font-family: var(--font-display);
  font-size: 0.52rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--text);
}
.loop-svg-overlay {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none; z-index: 3;
  border-radius: 50%;
}
.loop-info-panels { display: flex; flex-direction: column; gap: 0.6rem; }
.loop-panel {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-left: 2.5px solid var(--gold-500);
  border-radius: var(--radius-md);
  padding: 0.7rem 0.9rem;
  cursor: pointer;
}
.loop-panel.ring-active { border-left-color: var(--gold-300); background: rgba(212,160,23,0.06); }
.loop-panel-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.3rem; }
.loop-panel-icon { font-size: 1rem; }
.loop-panel-title {
  font-family: var(--font-display);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--gold-300);
}
.loop-panel-desc { font-size: 0.8rem; color: var(--text-dim); line-height: 1.6; }
.agent-terminal{background:#000;border:1px solid var(--border-gold);border-radius:var(--radius-lg);padding:.9rem;font-family:var(--font-terminal);font-size:.78rem;min-height:130px;margin-top:.9rem;}
.at-line{display:flex;align-items:flex-start;gap:.45rem;margin-bottom:.45rem;opacity:0;transform:translateY(4px);transition:all .35s;}
.at-line.visible{opacity:1;transform:translateY(0);}
.at-badge{flex-shrink:0;padding:.12rem .42rem;border-radius:3px;font-size:.62rem;font-weight:700;letter-spacing:.04em;font-family:var(--font-terminal);}
.at-plan{background:#1a3a2a;color:#34d399;}
.at-act{background:#1a2238;color:#60a5fa;}
.at-reflect{background:#2a1a3a;color:#c4b5fd;}
.at-done{background:#2a1e08;color:var(--gold-300);}
.at-text{color:var(--text-dim);}
/* --- AI Concepts cards --- */
.concept-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(215px,1fr));gap:1rem;margin-bottom:1.4rem;}
.concept-card{
  background:var(--bg-card);border:1px solid var(--border-soft);
  border-top:2px solid var(--border-gold);
  border-radius:var(--radius-md);padding:1.1rem;
  cursor:pointer;transition:all .28s var(--spring);
}
.concept-card:hover{transform:translateY(-4px);border-top-color:var(--gold-400);}
.cc-icon{font-size:1.9rem;margin-bottom:.55rem;}
.cc-name{font-family:var(--font-display);font-size:.78rem;font-weight:800;margin-bottom:.32rem;text-transform:uppercase;}
.cc-tagline{font-size:.78rem;color:var(--text-dim);margin-bottom:.55rem;line-height:1.6;}
.cc-badge{font-family:var(--font-terminal);font-size:.62rem;background:var(--gold-soft);border:1px solid var(--border-gold);border-radius:var(--radius-sm);padding:.18rem .55rem;color:var(--gold-400);}
/* --- safety timeline (full) --- */
.timeline{position:relative;padding:1.2rem 0;}
.timeline::before{content:'';position:absolute;top:0;bottom:0;left:22px;width:2px;background:linear-gradient(to bottom,var(--danger),var(--gold-400),var(--success));opacity:.4;}
@media(min-width:768px){.timeline::before{left:50%;transform:translateX(-50%);}}
.tl-item{position:relative;margin-bottom:1.6rem;padding-left:52px;}
@media(min-width:768px){.tl-item{display:flex;padding-left:0;justify-content:center;}.tl-item:nth-child(odd){flex-direction:row-reverse;}.tl-item:nth-child(odd) .tl-box{text-align:right;}}
.tl-dot{position:absolute;left:10px;top:0;width:24px;height:24px;border-radius:50%;background:var(--navy-600);border:2.5px solid var(--gold-500);display:flex;align-items:center;justify-content:center;z-index:2;font-size:.65rem;}
@media(min-width:768px){.tl-dot{left:50%;transform:translateX(-50%);}}
.tl-item:hover .tl-dot{background:var(--gold-500);box-shadow:0 0 14px var(--gold-glow);}
.tl-box{background:var(--bg-card);border:1px solid var(--border-soft);border-top:1.5px solid var(--border-gold);border-radius:var(--radius-md);padding:1rem 1.1rem;max-width:420px;width:100%;cursor:pointer;transition:all .3s;}
.tl-box:hover{border-top-color:var(--gold-400);transform:translateY(-2px);}
@media(min-width:768px){.tl-box{margin:0 36px;}}
.tl-step{font-family:var(--font-terminal);font-size:.62rem;color:var(--gold-400);letter-spacing:.1em;margin-bottom:.2rem;text-transform:uppercase;}
.tl-title{font-family:var(--font-display);font-size:.76rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;display:flex;align-items:center;justify-content:space-between;}
.tl-desc{font-size:.8rem;color:var(--text-dim);line-height:1.6;}
.tl-detail{display:none;margin-top:.8rem;padding-top:.8rem;border-top:1px solid rgba(255,255,255,.07);}
.tl-box.open .tl-detail{display:block;}
.tl-box.open .chev{transform:rotate(180deg);}
.chev{transition:transform .3s;color:var(--text-muted);}
.risk-box{font-size:.8rem;padding:.65rem;border-radius:var(--radius-sm);margin-bottom:.5rem;line-height:1.55;}
.risk-in{background:rgba(224,80,80,.07);border-left:2.5px solid var(--danger);}
.risk-out{background:rgba(0,204,136,.07);border-left:2.5px solid var(--success);}
.risk-title{font-family:var(--font-terminal);font-size:.62rem;font-weight:700;margin-bottom:.2rem;display:flex;align-items:center;gap:.3rem;text-transform:uppercase;}
.risk-in .risk-title{color:#fca5a5;}
.risk-out .risk-title{color:#6ee7b7;}
.risk-tag{background:rgba(224,80,80,.07);border:1px solid var(--danger);padding:.28rem .72rem;border-radius:var(--radius-sm);font-family:var(--font-terminal);font-size:.72rem;color:#fca5a5;cursor:pointer;display:inline-block;margin:.25rem;}
.safety-infographic{background:linear-gradient(135deg,rgba(5,12,28,.98),rgba(2,6,16,.98));border:1px solid var(--border-gold);border-radius:var(--radius-xl);padding:1.8rem 1.5rem;margin:1.5rem 0;position:relative;}
.si-title{font-family:var(--font-display);font-size:.88rem;font-weight:800;color:var(--text);margin-bottom:.35rem;display:flex;align-items:center;gap:.55rem;text-transform:uppercase;}
.si-subtitle{font-size:.8rem;color:var(--text-dim);margin-bottom:1.5rem;}
.si-layers{display:flex;flex-direction:column;}
.si-layer{display:flex;align-items:center;gap:.85rem;padding:.55rem .85rem;border-radius:var(--radius-md);margin-bottom:3px;cursor:pointer;}
.si-layer-num{width:26px;height:26px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-family:var(--font-terminal);font-weight:700;font-size:.68rem;}
.si-layer-content{flex:1;}
.si-layer-title{font-family:var(--font-display);font-weight:700;font-size:.68rem;letter-spacing:.04em;text-transform:uppercase;}
.si-layer-tag{font-size:.64rem;color:var(--text-dim);}
.si-layer-icon{font-size:.95rem;}
.si-layer-bar{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:4px;}
.si-stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(105px,1fr));gap:.7rem;margin-top:1.5rem;}
.si-stat{background:rgba(0,0,0,.28);border:1px solid var(--border-gold);border-radius:var(--radius-md);padding:.8rem;text-align:center;}
.si-stat-num{font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--gold-300);}
.si-stat-label{font-family:var(--font-terminal);font-size:.6rem;color:var(--text-dim);text-transform:uppercase;}
/* --- mind map --- */
.mm-outer{max-width:1100px;margin:0 auto;padding:1.5rem 1rem 3rem;}
.mm-hero{text-align:center;margin-bottom:1.8rem;}
.mm-hero h1{font-family:var(--font-display);font-size:clamp(1.4rem,4vw,2.5rem);font-weight:800;text-transform:uppercase;background:linear-gradient(135deg,var(--text) 30%,var(--gold-400));-webkit-background-clip:text;background-clip:text;color:transparent;}
.mm-wrap{position:relative;width:100%;min-height:660px;}
#mmCanvas{position:relative;width:100%;min-height:660px;}
.mm-hub{
  position:absolute;z-index:10;width:165px;height:165px;
  top:50%;left:50%;transform:translate(-50%,-50%);
  background:linear-gradient(135deg,rgba(212,160,23,.2),rgba(212,160,23,.07));
  border:2px solid var(--gold-500);
  border-radius:var(--radius-lg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;
  box-shadow:0 0 0 8px rgba(212,160,23,.06),0 0 0 16px rgba(212,160,23,.03),0 16px 40px rgba(0,0,0,.5);
}
.mm-hub-title{font-family:var(--font-display);font-size:.68rem;font-weight:800;color:var(--gold-300);margin-top:.4rem;text-transform:uppercase;}
.mm-hub-sub{font-family:var(--font-terminal);font-size:.56rem;color:var(--gold-500);}
.mm-node{
  position:absolute;z-index:5;width:185px;
  background:var(--bg-card);backdrop-filter:blur(16px);
  border:1px solid var(--border-gold);
  border-radius:var(--radius-md);padding:.8rem .7rem;
  cursor:pointer;transition:all .28s var(--spring);text-align:center;
}
.mm-node-name{font-family:var(--font-display);font-size:1.05rem;font-weight:800;color:var(--gold-300);margin-bottom:.25rem;text-transform:uppercase;}
.mm-node-form{font-family:var(--font-terminal);font-size:.6rem;color:var(--text-dim);background:rgba(0,0,0,.28);border-radius:3px;padding:2px 6px;display:inline-block;}
.mm-node-cta{font-family:var(--font-terminal);font-size:.6rem;color:rgba(212,160,23,.7);display:flex;align-items:center;justify-content:center;gap:.3rem;}
@media(max-width:820px){
  #mmCanvas{display:flex;flex-direction:column;align-items:center;gap:1rem;min-height:auto!important;}
  .mm-hub{position:relative!important;transform:none!important;margin-bottom:1rem;}
  .mm-node{position:relative!important;width:100%!important;max-width:380px;transform:none!important;}
  #mmSvg{display:none!important;}
}
/* --- modal --- */
.modal-bg{position:fixed;inset:0;z-index:1000;background:rgba(1,5,16,.88);backdrop-filter:blur(22px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .22s;}
.modal-bg.open{opacity:1;pointer-events:all;}
.modal{background:var(--navy-700);border:1px solid var(--border-gold);border-top:2px solid var(--gold-400);border-radius:var(--radius-xl);max-width:560px;width:100%;max-height:88vh;overflow-y:auto;transform:scale(.9) translateY(14px);transition:transform .3s var(--spring);}
.modal-bg.open .modal{transform:scale(1) translateY(0);}
.modal-titlebar{padding:.45rem 1.1rem;background:linear-gradient(90deg,var(--gold-500),var(--gold-300));display:flex;align-items:center;gap:.45rem;}
.modal-titlebar-text{font-family:var(--font-terminal);font-size:.62rem;color:var(--navy-900);font-weight:700;flex:1;text-transform:uppercase;}
.modal-head{padding:.9rem 1.4rem .7rem;border-bottom:1px solid var(--border-soft);display:flex;align-items:center;justify-content:space-between;}
.modal-head h2{font-family:var(--font-display);font-size:1.1rem;font-weight:800;color:var(--gold-300);text-transform:uppercase;}
.modal-close{background:rgba(255,255,255,.05);border:1px solid var(--border-gold);color:var(--text-dim);width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:var(--radius-sm);cursor:pointer;}
.modal-bd{padding:1.1rem 1.4rem 1.6rem;}
.m-sec{margin-bottom:1rem;}
.m-label{font-family:var(--font-terminal);font-size:.6rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-500);margin-bottom:.3rem;}
.m-text{font-size:.85rem;color:var(--text);line-height:1.72;}
.m-letters{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.35rem;}
.m-chip{background:var(--gold-soft);border:1px solid var(--border-gold);border-radius:var(--radius-sm);padding:.3rem .6rem;font-size:.74rem;}
.m-chip strong{color:var(--gold-300);}
.m-prompt{background:rgba(0,0,0,.4);border:1px solid var(--border-gold);border-left:3px solid var(--gold-500);border-radius:0 var(--radius-md) var(--radius-md) 0;padding:.8rem 1rem;font-family:var(--font-terminal);font-size:.74rem;color:var(--text);}
/* --- pyramid, layers, resources styles (full) --- */
.pyramid-stack{display:flex;flex-direction:column;align-items:center;margin:1.5rem auto;max-width:580px;}
.py-layer{width:100%;cursor:pointer;border:1.5px solid transparent;margin-bottom:.3rem;}
.py-layer-inner{display:flex;align-items:center;gap:1rem;padding:.95rem 1.2rem;}
.py-num{width:26px;height:26px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-family:var(--font-terminal);font-weight:700;font-size:.75rem;background:rgba(0,0,0,.3);}
.py-content{flex:1;}
.py-title{font-family:var(--font-display);font-size:.82rem;font-weight:800;margin-bottom:.15rem;text-transform:uppercase;}
.py-tagline{font-size:.75rem;opacity:.72;}
.py-icon{font-size:1.5rem;}
.py-arrow{display:flex;justify-content:center;padding:.12rem 0;}
.py-arrow-anim{animation:arrowBounce 1.6s ease-in-out infinite;}
@keyframes arrowBounce{0%,100%{opacity:.25;transform:translateY(0);}50%{opacity:.9;transform:translateY(3px);}}
.py-detail-panel{background:rgba(0,0,0,.4);border-radius:var(--radius-md);margin-top:.7rem;max-height:0;transition:max-height .42s ease,opacity .3s;opacity:0;overflow:hidden;}
.py-detail-panel.open{max-height:600px;opacity:1;}
.py-detail-inner{padding:1.3rem;}
.py-detail-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;margin-top:.9rem;}
@media(max-width:600px){.py-detail-grid{grid-template-columns:1fr;}}
.py-dcard{border-radius:var(--radius-sm);padding:.85rem;font-size:.8rem;line-height:1.55;}
